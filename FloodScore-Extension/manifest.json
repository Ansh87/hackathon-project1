{
  "manifest_version": 3,
  "name": "FloodScore",
  "description": "Overlay climate-adjusted flood risk insights on Zillow and Redfin listings.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.zillow.com/*",
    "*://*.redfin.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.zillow.com/*", "*://*.redfin.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "FloodScore",
    "default_popup": "popup.html"
  }
}
